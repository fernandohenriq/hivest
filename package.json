{
  "name": "hivest",
  "description": "Featherweight modular HTTP framework for TypeScript",
  "version": "0.0.2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "fernandohenriqsilva@gmail.com",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "cross-env NODE_ENV=production node ./build/src/index.js",
    "build": "cross-env NODE_ENV=production npx tsc",
    "test": "cross-env NODE_ENV=test vitest --config vitest.config.mts",
    "pub:major": "npm version major && npm run build && npm publish",
    "pub:minor": "npm version minor && npm run build && npm publish",
    "pub:patch": "npm version patch && npm run build && npm publish"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongo": "^0.1.0",
    "mongoose": "^8.6.3",
    "mongoose-paginate-v2": "^1.8.5",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "winston": "^3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.5",
    "@types/supertest": "^6.0.2",
    "@types/winston": "^2.4.4",
    "mongodb-memory-server": "^10.1.3",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "decorators",
    "dependency injection",
    "typescript",
    "module system",
    "ioc container"
  ]
}
