{
  "name": "hivest",
  "description": "Featherweight modular HTTP framework for TypeScript",
  "version": "0.0.3",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "fernandohenriqsilva@gmail.com",
  "homepage": "https://github.com/fernandohenriq/hivest",
  "license": "MIT",
  "private": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "start": "cross-env NODE_ENV=production node ./dist/index.js",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsup src/index.ts --outDir dist --format esm,cjs --dts",
    "test": "cross-env NODE_ENV=test vitest --config vitest.config.mts",
    "major": "npm version major && git push && npm run build && npm publish",
    "minor": "npm version minor && git push && npm run build && npm publish",
    "patch": "npm version patch && git push && npm run build && npm publish"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongo": "^0.1.0",
    "mongoose": "^8.6.3",
    "mongoose-paginate-v2": "^1.8.5",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "winston": "^3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.5",
    "@types/supertest": "^6.0.2",
    "@types/winston": "^2.4.4",
    "mongodb-memory-server": "^10.1.3",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "decorators",
    "dependency injection",
    "typescript",
    "module system",
    "ioc container"
  ]
}
